<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>صدمة واجهات 😈</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      height: 100vh;
      overflow: hidden;
      background: radial-gradient(circle at top, #0ff 0, #000 55%, #000 100%);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      cursor: none;
    }

    canvas#matrix {
      position: fixed;
      inset: 0;
      z-index: 0;
      opacity: 0.35;
    }

    .cursor {
      position: fixed;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      border: 2px solid #0ff;
      box-shadow: 0 0 18px #0ff;
      pointer-events: none;
      transform: translate(-50%, -50%);
      z-index: 10;
      mix-blend-mode: screen;
      transition: transform 0.08s ease-out, width 0.08s, height 0.08s;
    }

    .cursor.click {
      width: 40px;
      height: 40px;
      transform: translate(-50%, -50%) scale(0.7);
    }

    .noise {
      pointer-events: none;
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.2' numOctaves='3' stitchTiles='noStitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.18'/%3E%3C/svg%3E");
      mix-blend-mode: soft-light;
      z-index: 1;
    }

    .wrapper {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      perspective: 1200px;
      width: 100%;
      padding: 20px;
    }

    .card {
      position: relative;
      width: min(480px, 90vw);
      padding: 32px 28px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(0, 255, 255, 0.12), rgba(0, 0, 0, 0.8));
      border: 1px solid rgba(0, 255, 255, 0.35);
      box-shadow:
        0 0 25px rgba(0, 255, 255, 0.35),
        0 30px 80px rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(18px);
      transform-style: preserve-3d;
      transform: rotateY(12deg) rotateX(8deg);
      transition: transform 0.25s ease-out, box-shadow 0.25s ease-out;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: -40%;
      background: conic-gradient(
        from 180deg,
        rgba(0, 255, 255, 0.0),
        rgba(0, 255, 255, 0.5),
        rgba(255, 0, 255, 0.0),
        rgba(0, 255, 255, 0.0)
      );
      opacity: 0.35;
      mix-blend-mode: screen;
      animation: spin 8s linear infinite;
      pointer-events: none;
    }

    .card::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top left, rgba(0, 255, 255, 0.25), transparent 55%);
      mix-blend-mode: screen;
      opacity: 0.7;
      pointer-events: none;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.6);
      border: 1px solid rgba(0, 255, 255, 0.5);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #aafcff;
      margin-bottom: 18px;
    }

    .badge-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #0ff;
      box-shadow: 0 0 12px #0ff;
    }

    h1 {
      font-size: 28px;
      line-height: 1.3;
      margin-bottom: 10px;
      text-shadow: 0 0 18px rgba(0, 255, 255, 0.7);
    }

    .gradient-text {
      background: linear-gradient(120deg, #0ff, #ff00ff, #ffea00);
      /* أضف السطر الثاني ليتوافق مع المتصفحات الحديثة */
-webkit-background-clip: text; 
background-clip: text;
      color: transparent;
    }

    .typewriter {
      min-height: 26px;
      font-size: 16px;
      color: #e0ffff;
      margin-bottom: 18px;
      white-space: pre-wrap;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 12px;
      color: #9bd9ff;
      margin-bottom: 18px;
      opacity: 0.9;
    }

    .meta span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .meta span::before {
      content: "◆";
      font-size: 8px;
      color: #0ff;
    }

    .buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 10px;
    }

    .btn {
      position: relative;
      padding: 10px 18px;
      border-radius: 999px;
      border: 1px solid rgba(0, 255, 255, 0.7);
      background: radial-gradient(circle at top, rgba(0, 255, 255, 0.25), rgba(0, 0, 0, 0.9));
      color: #e0ffff;
      font-size: 13px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      cursor: pointer;
      overflow: hidden;
      transition: transform 0.15s ease-out, box-shadow 0.15s ease-out, background 0.15s ease-out;
      box-shadow: 0 0 14px rgba(0, 255, 255, 0.4);
    }

    .btn span {
      position: relative;
      z-index: 1;
    }

    .btn::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, rgba(0, 255, 255, 0.4), rgba(255, 0, 255, 0.3));
      opacity: 0;
      transition: opacity 0.2s ease-out;
    }

    .btn:hover {
      transform: translateY(-2px) scale(1.02);
      box-shadow:
        0 0 20px rgba(0, 255, 255, 0.7),
        0 0 40px rgba(255, 0, 255, 0.4);
    }

    .btn:hover::before {
      opacity: 1;
    }

    .btn.secondary {
      border-color: rgba(255, 255, 255, 0.4);
      background: rgba(0, 0, 0, 0.8);
      box-shadow: 0 0 10px rgba(255, 255, 255, 0.25);
    }

    .footer {
      margin-top: 18px;
      font-size: 11px;
      color: #7fb7ff;
      opacity: 0.9;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
    }

    .pulse-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #0f0;
      box-shadow: 0 0 12px #0f0;
      animation: pulse 1.4s infinite;
    }

    @keyframes pulse {
      0% {
        transform: scale(0.9);
        opacity: 0.7;
      }
      50% {
        transform: scale(1.2);
        opacity: 1;
      }
      100% {
        transform: scale(0.9);
        opacity: 0.7;
      }
    }

    @media (max-width: 480px) {
      .card {
        padding: 24px 18px;
        transform: none !important;
      }
      h1 {
        font-size: 22px;
      }
      .typewriter {
        font-size: 14px;
      }
      body {
        cursor: default;
      }
      .cursor {
        display: none;
      }
    }
  </style>
</head>

<body>
  <canvas id="matrix"></canvas>
  <div class="noise"></div>
  <div class="cursor"></div>

  <div class="wrapper">
    <div class="card" id="card">
      <div class="badge">
        <div class="badge-dot"></div>
        <span>Front‑End Shock Demo</span>
      </div>

      <h1>
        واجهة <span class="gradient-text">مو عادية</span>،
        مكتوبة بـ HTML / CSS / JS
      </h1>

      <div class="typewriter" id="typewriter"></div>

      <div class="meta">
        <span>تفاعل حي مع حركة الماوس</span>
        <span>Matrix Rain Canvas</span>
        <span>Neon + Glassmorphism</span>
      </div>

      <div class="buttons">
        <button class="btn" id="btnGlitch">
          <span>فعّل الصدمة</span>
        </button>
        <button class="btn secondary" id="btnCopy">
          <span>انسخ النص المتحرك</span>
        </button>
      </div>

      <div class="footer">
        <div style="display:flex;align-items:center;gap:8px;">
          <div class="pulse-dot"></div>
          <span>كل شيء يصير بالـ Front‑End بس.</span>
        </div>
        <span style="opacity:0.8;">حرّك الماوس ✦ اضغط الأزرار</span>
      </div>
    </div>
  </div>

  <script>
    const cursor = document.querySelector(".cursor");
    window.addEventListener("mousemove", (e) => {
      cursor.style.left = e.clientX + "px";
      cursor.style.top = e.clientY + "px";
    });

    window.addEventListener("mousedown", () => cursor.classList.add("click"));
    window.addEventListener("mouseup", () => cursor.classList.remove("click"));

    const card = document.getElementById("card");
    window.addEventListener("mousemove", (e) => {
      const x = (e.clientX / window.innerWidth - 0.5) * 2;
      const y = (e.clientY / window.innerHeight - 0.5) * 2;
      card.style.transform =
        `rotateY(${x * 14}deg) rotateX(${-y * 10}deg) translateZ(8px)`;
    });

    const canvas = document.getElementById("matrix");
    const ctx = canvas.getContext("2d");

    let width = canvas.width = window.innerWidth;
    let height = canvas.height = window.innerHeight;

    const letters = "01<>/={}[]*&$#@!^";
    const fontSize = 16;
    let columns = Math.floor(width / fontSize);
    let drops = Array.from({ length: columns }, () => Math.random() * -20);

    function drawMatrix() {
      ctx.fillStyle = "rgba(0, 0, 0, 0.18)";
      ctx.fillRect(0, 0, width, height);

      ctx.fillStyle = "#0ff";
      ctx.font = fontSize + "px monospace";

      for (let i = 0; i < drops.length; i++) {
        const text = letters.charAt(Math.floor(Math.random() * letters.length));
        const x = i * fontSize;
        const y = drops[i] * fontSize;

        ctx.fillText(text, x, y);

        if (y > height && Math.random() > 0.96) drops[i] = 0;
        drops[i] += 0.9 + Math.random() * 0.4;
      }

      requestAnimationFrame(drawMatrix);
    }

    drawMatrix();

    window.addEventListener("resize", () => {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
      columns = Math.floor(width / fontSize);
      drops = Array.from({ length: columns }, () => Math.random() * -20);
    });

    const typewriterEl = document.getElementById("typewriter");
    const lines = [
      "هذا المثال مو بس تصميم حلو،",
      "هو استعراض تفاعل بين:",
      "• Canvas + JavaScript للـ Matrix Rain",
      "• CSS Glassmorphism + Neon + Noise",
      "• حركة الماوس تعطي 3D Parallax للبطاقة",
      "",
      "كل هذا في صفحة HTML وحدة فقط."
    ];

    let lineIndex = 0;
    let charIndex = 0;
    let currentLine = "";
    let isDeleting = false;

    function type() {
      const fullLine = lines[lineIndex];

      if (!isDeleting) {
        currentLine = fullLine.slice(0, charIndex + 1);
        charIndex++;
        if (charIndex === fullLine.length) {
          setTimeout(() => (isDeleting = true), 900);
        }
      } else {
        currentLine = fullLine.slice(0, charIndex - 1);
        charIndex--;
        if (charIndex === 0) {
          isDeleting = false;
          lineIndex = (lineIndex + 1) % lines.length;
        }
      }

      typewriterEl.textContent = currentLine;

      const speed = isDeleting ? 35 : 55;
      setTimeout(type, speed);
    }

    type();

    
    // 1. تأكد من تعريف العناصر أولاً
    const btnGlitch = document.getElementById("btnGlitch"); // تأكد من وجود ID بهذا الاسم في الـ HTML
    const btnCopy = document.getElementById("btnCopy");

    // 2. تصحيح كود الـ animate (يجب أن يكون لعنصر موجود)
    if (btnGlitch) {
        btnGlitch.addEventListener("click", () => {
            btnGlitch.animate([
                { filter: "hue-rotate(-40deg) contrast(1.3)" }, // الإطار الأول
                { filter: "hue-rotate(0deg) contrast(1)" }      // الإطار الأخير
            ], {
                duration: 420,
                easing: "ease-out"
            });
        });
    }

    // 3. تصحيح كود النسخ
    if (btnCopy) {
        btnCopy.addEventListener("click", async () => {
            try {
                // تأكد من تعريف المصفوفة lines أو استبدلها بالنص المراد نسخه
                await navigator.clipboard.writeText(lines.join("\n"));
                
                const span = btnCopy.querySelector("span");
                if (span) {
                    span.textContent = "تم النسخ"; // النص الجديد
                    setTimeout(() => {
                        span.textContent = "تحرك"; // النص الأصلي
                    }, 1400);
                }
            } catch (e) {
                console.error("فشل النسخ:", e);
                alert("حدث خطأ، يرجى النسخ يدوياً");
            }
        });
    }
</script>
</body>
</html>